# ============ Node / 依赖 ============
**/node_modules/
**/.npm/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# ============ 构建产物 ============
backend/dist/
frontend/dist/
frontend/dev-dist/
*.tsbuildinfo

# ============ 运行时数据 (本地) ============
# 注意: 不带前导 '/' 的目录名会匹配任意层级 — 例如裸 'logs/' 会误伤
# backend/src/modules/logs/ 这种源码目录, 导致 CI checkout 后缺文件。
# 这里全部锁到具体路径。
/database/
backend/database/
/logs/
backend/logs/
*.db
*.db-journal
*.sqlite
*.sqlite3

# ============ 环境变量 (敏感) ============
backend/.env
backend/.env.local
backend/.env.*.local
frontend/.env.local
frontend/.env.*.local
# 保留示例文件
!**/.env.example

# ============ PWA / Vite 缓存 ============
frontend/.vite/
frontend/.cache/

# ============ IDE / 编辑器 ============
.vscode/
.idea/
*.swp
*.swo
*~

# ============ macOS / Windows ============
.DS_Store
Thumbs.db

# ============ 临时 / 部署中间产物 ============
/tmp-deploy/
/deploy-staging/
*.tar.gz
*.tgz

# ============ 测试覆盖率 ============
coverage/
.nyc_output/

# ============ 现场主控机本地文件 (GK9000) ============
# 现场会自己生成的脚本/备份/npmrc, 不进仓库
/start-backend.ps1
/start-frontend.ps1
backend/.env.bak*
backend/.npmrc
/tmp/
/logs/auto-update-*.log
