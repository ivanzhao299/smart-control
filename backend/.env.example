# ===========================================
# 展贸中心智能化中控系统 - 环境变量
# ===========================================

# 应用配置
PORT=3000
NODE_ENV=development
APP_NAME=smart-control-backend

# 数据库配置 (SQLite)
DB_PATH=../database/smart-control.db
DB_SYNCHRONIZE=true
DB_LOGGING=false

# 日志配置
LOG_LEVEL=info
LOG_DIR=../logs
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m

# API 配置
API_PREFIX=/api
API_TIMEOUT=30000

# 设备适配器: MOCK_MODE=true 时所有适配器返回 mock 数据 (不发真实协议)
MOCK_MODE=true
MOCK_LATENCY_MS=80
DEVICE_TIMEOUT_MS=3000
DEVICE_RETRIES=3

# 设备健康检查 (定时探活)
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_MS=15000

# ============ DALI 灯光 ============
# 适配器选型: cy-dali64a (默认, 元创智控 RS485 Modbus RTU) | iot-gateway (通用 HTTP REST) | mock
LIGHTING_ADAPTER_KIND=cy-dali64a

# CY-DALI64A (走 RTU-over-TCP 转换器, 例如 USR-TCP232 / Moxa MGate)
DALI_RTU_HOST=192.168.50.20
DALI_RTU_PORT=502
DALI_RTU_SLAVE_ID=1              # 网关拨码盘地址, 多台并联各设不同号
DALI_RTU_FRAME_INTERVAL_MS=200   # 帧间隔, 文档要求 ≥150ms
DALI_RTU_DEFAULT_FADE_SEC=0.7    # 默认渐变时间

# (向后兼容) DALI IoT Gateway HTTP REST — 仅 LIGHTING_ADAPTER_KIND=iot-gateway 时使用
DALI_GATEWAY_HOST=192.168.50.20
DALI_GATEWAY_PORT=80
DALI_API_PATH=/control
# DALI_API_KEY=

# ============ LED 大屏 (诺瓦 NovaStar VX1000 + Intel NUC) ============
# VX1000 视频处理器 (TCP:5200, NovaStar VX 私有 hex 协议)
LED_HOST=192.168.50.30
LED_PORT=5200
# 屏幕分辨率 (现场实际 LED 模组拼接后的总像素), 影响图层全屏占位计算
LED_RESOLUTION_WIDTH=1920
LED_RESOLUTION_HEIGHT=1080
# welcome / video 切到哪个 VX1000 预设号 (1-10)
LED_PRESET_WELCOME=1
LED_PRESET_VIDEO=2
# 开屏后默认亮度 (0-100)
LED_DEFAULT_BRIGHTNESS_PCT=80

# NUC 媒体播控主机 (可选, 设了才支持播放具体视频文件)
# LED_NUC_HOST=192.168.50.31
# LED_NUC_PORT=8080

# 音响 DSP (DSPPA / ITC)
AUDIO_HOST=192.168.50.40
AUDIO_PORT=80
AUDIO_DEFAULT_ZONE=1f_bg
# AUDIO_API_KEY=

# ============ 空调 (奥克斯商用 VRF ARV-X9 + 中弘 B 集控网关 TCP 款) ============
# 外机: 2 台 (一拖多)
#   - 1F: 奥克斯 DLR-785W5/DCM-ARVX9, 35.5 kW, 57A (带 10 台内机)
#   - 2F: 奥克斯 DLR-1015W5/DCM-ARVX9, 40.8 kW, 64A (带 12 台内机)
# 网关: 2 台中弘 B 集控网关 TCP 款 (各 ~¥1,200, 协议 MBT V3.2)
#   - 1F 网关 192.168.50.51:502 → 1F 外机 → 内机 n=0..9
#   - 2F 网关 192.168.50.52:502 → 2F 外机 → 内机 n=0..11
#   - 直接接弱电交换机, 不需要 USR-TCP232 转换器
# 内机寻址 (device.address JSON):
#   {"gwHost":"192.168.50.51","n":0,"model":"DLR-63F","kw":1.8}
#   寄存器映射见 backend/src/adapters/hvac/zhonghong-mbt-protocol.ts
#   状态地址 = 6n; 控制地址 = 4000 + 4n
# 下面 HVAC_HOST/HVAC_PORT 仅给健康检查 ping 用 (默认 ping 1F 网关)
HVAC_HOST=192.168.50.51
HVAC_PORT=502
HVAC_DEFAULT_SLAVE_ID=1

# WebSocket
WS_PATH=/ws/status
