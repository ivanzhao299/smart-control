# ===========================================
# 展贸中心智能化中控系统 - 环境变量
# ===========================================

# 应用配置
PORT=3000
NODE_ENV=development
APP_NAME=smart-control-backend

# 数据库配置 (SQLite)
DB_PATH=../database/smart-control.db
DB_SYNCHRONIZE=true
DB_LOGGING=false

# 日志配置
LOG_LEVEL=info
LOG_DIR=../logs
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m

# API 配置
API_PREFIX=/api
API_TIMEOUT=30000

# 设备适配器: MOCK_MODE=true 时所有适配器返回 mock 数据 (不发真实协议)
MOCK_MODE=true
MOCK_LATENCY_MS=80
DEVICE_TIMEOUT_MS=3000
DEVICE_RETRIES=3

# 设备健康检查 (定时探活)
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_MS=15000

# ============ DALI 灯光 ============
# 适配器选型: cy-dali64a (默认, 元创智控 RS485 Modbus RTU) | iot-gateway (通用 HTTP REST) | mock
LIGHTING_ADAPTER_KIND=cy-dali64a

# CY-DALI64A (走 RTU-over-TCP 转换器, 例如 USR-TCP232 / Moxa MGate)
DALI_RTU_HOST=192.168.50.20
DALI_RTU_PORT=502
DALI_RTU_SLAVE_ID=1              # 网关拨码盘地址, 多台并联各设不同号
DALI_RTU_FRAME_INTERVAL_MS=200   # 帧间隔, 文档要求 ≥150ms
DALI_RTU_DEFAULT_FADE_SEC=0.7    # 默认渐变时间

# (向后兼容) DALI IoT Gateway HTTP REST — 仅 LIGHTING_ADAPTER_KIND=iot-gateway 时使用
DALI_GATEWAY_HOST=192.168.50.20
DALI_GATEWAY_PORT=80
DALI_API_PATH=/control
# DALI_API_KEY=

# LED 大屏 (诺瓦 VX1000 + Intel NUC)
LED_HOST=192.168.50.30
LED_PORT=5200
LED_TRANSPORT=tcp    # tcp | http

# 音响 DSP (DSPPA / ITC)
AUDIO_HOST=192.168.50.40
AUDIO_PORT=80
AUDIO_DEFAULT_ZONE=1f_bg
# AUDIO_API_KEY=

# 空调 (奥克斯中央空调 + Modbus TCP)
HVAC_HOST=192.168.50.50
HVAC_PORT=502
HVAC_DEFAULT_SLAVE_ID=1

# WebSocket
WS_PATH=/ws/status
