# ============================================================
# 中控主机 (Windows 10 / GIADA GK9000) 配置示例
# 复制为 backend\.env 后按现场情况修改
# ============================================================

# --- App ---
PORT=3000
NODE_ENV=production
APP_NAME=smart-control-backend
API_PREFIX=/api
API_TIMEOUT=30000

# 现场主机标识 (随 /api/system/health 返回, 便于运维识别)
HOST_MACHINE=GIADA GK9000
PLATFORM=windows

# --- 数据库 (SQLite, 注意 Windows 路径用双反斜杠或正斜杠都可) ---
DB_PATH=D:\smart-control\database\smart-control.db
DB_SYNCHRONIZE=true
DB_LOGGING=false

# --- 日志 (winston) ---
LOG_LEVEL=info
LOG_DIR=D:\smart-control\logs
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m

# --- 设备适配器 ---
# 现场对接真实设备后改为 false
MOCK_MODE=true
MOCK_LATENCY_MS=60
DEVICE_TIMEOUT_MS=3000
DEVICE_RETRIES=3

# --- 健康检查 / 自动重连 ---
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_MS=30000

# --- DALI 灯光网关 (英飞特 / Lunatone) ---
DALI_GATEWAY_HOST=192.168.50.20
DALI_GATEWAY_PORT=80
DALI_API_PATH=/control
# DALI_API_KEY=<在现场配置厂家提供的 API Key>

# --- 诺瓦 VX1000 LED + Intel NUC 播控 ---
LED_HOST=192.168.50.30
LED_PORT=5200
LED_TRANSPORT=tcp

# --- 音响 DSP (DSPPA / ITC) ---
AUDIO_HOST=192.168.50.40
AUDIO_PORT=80
AUDIO_DEFAULT_ZONE=1f_bg
# AUDIO_API_KEY=

# --- 奥克斯中央空调 (Modbus TCP) ---
HVAC_HOST=192.168.50.50
HVAC_PORT=502
HVAC_DEFAULT_SLAVE_ID=1

# --- WebSocket ---
WS_PATH=/ws/status

# --- 测试模式 (Sprint-09) ---
TEST_MODE=false
